{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xiangchen/Ramanujan-Dataset/data/schema.json",
  "title": "Ramanujan's Formulae",
  "description": "A labeled Entry, Corollary, or Example from Berndt's edited volumes.",
  "type": "object",
  "required": ["id", "content", "topics"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable identifier, e.g. RN-P1-C02-Entry05-Example09",
      "pattern": "^(RN|RLN)-P[1-5]-C[0-9]{2}-.+$"
    },
    "content": {
      "type": "string",
      "description": "Full mathematical statement in LaTeX; no proofs"
    },
    "topics": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
